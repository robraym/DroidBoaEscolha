<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/one_ui_stroke_soft" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/one_ui_surface_alt" />
            <stroke
                android:width="1dp"
                android:color="@color/one_ui_stroke" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
