<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scannerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/scannerTopPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#B3000000"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="20dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/txtScannerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Escanear código"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtScannerStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Aponte a câmera para o código de barras do produto."
            android:textColor="#D6FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

    <View
        android:layout_width="248dp"
        android:layout_height="128dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_scanner_frame" />

    <LinearLayout
        android:id="@+id/scannerActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="22dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnManualBarcode"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_primary"
            android:text="Digitar código de barras"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTorch"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="Lanterna"
                android:textAllCaps="false"
                android:textColor="@color/one_ui_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCancelScan"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="Cancelar"
                android:textAllCaps="false"
                android:textColor="@color/one_ui_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
